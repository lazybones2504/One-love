<!DOCTYPE html><html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Something for You ❤️</title>
<style>
body{font-family:Arial,Helvetica,sans-serif;background:#ffeef2;text-align:center;padding:40px}
.container{max-width:600px;margin:auto;background:white;padding:30px;border-radius:15px;box-shadow:0 10px 25px rgba(0,0,0,0.1)}
.hidden{display:none}
button{padding:10px 20px;margin:10px;border:none;border-radius:10px;background:#ff4d6d;color:white;font-size:16px;cursor:pointer}
button:hover{opacity:0.9}
input{padding:10px;margin:10px;width:80%}
#noBtn{position:relative}
</style>
</head>
<body>
<div class="container">
<h2>Hey Sneha 👀</h2>
<p>First like this photo to continue.</p>
<img src="https://images.unsplash.com/photo-1518199266791-5375a83190b7" width="250" id="photo">
<br>
<button onclick="likePhoto()">❤️ Like</button><div id="puzzle" class="hidden">
<h3>Puzzle Time 😏</h3>
<p>What is 7 + 5 × 2 ?</p>
<input id="answer" placeholder="Your answer">
<br>
<button onclick="checkAnswer()">Submit</button>
</div><div id="message" class="hidden">
<h3>You solved it! 🥳</h3>
<p>So… I was wondering…</p>
<h2>Would you like to go on a coffee date with me? ☕</h2>
<button onclick="yesClicked()">Yes ❤️</button>
<button id="noBtn" onmouseover="moveNo()">No 😅</button>
</div><div id="form" class="hidden">
<h3>One last thing 😌</h3>
<form>
<input placeholder="Your mood right now">
<br>
<input placeholder="Favourite coffee">
<br>
<input placeholder="When are you free?">
<br>
<button type="submit">Submit</button>
</form>
<p>Can't wait for our coffee ☕❤️</p>
</div></div><script>
function likePhoto(){
 document.getElementById('puzzle').classList.remove('hidden')
}

function checkAnswer(){
 let ans=document.getElementById('answer').value
 if(ans=="17"){
 document.getElementById('message').classList.remove('hidden')
 }else{
 alert("Try again 😜")
 }
}

function moveNo(){
 let btn=document.getElementById('noBtn')
 btn.style.position='absolute'
 btn.style.top=Math.random()*300+'px'
 btn.style.left=Math.random()*300+'px'
}

function yesClicked(){
 document.getElementById('form').classList.remove('hidden')
}
</script></body>
</html>you 
